ARG BINARY=portal
# debian:bookworm-slim is glibc-based, but we build with CGO_ENABLED=0 so
# the binary is fully static — the only runtime dependency here is git.
# Use git:alpine to get git without pulling in a full Debian layer.
FROM alpine:3.21
ARG BINARY
ARG TARGETOS
ARG TARGETARCH
RUN apk add --no-cache git
COPY ${BINARY}-${TARGETOS}-${TARGETARCH} /usr/local/bin/portal
EXPOSE 8443
ENTRYPOINT ["/usr/local/bin/portal"]
