# Portal binary (built by go build)
/portal

# Router binary (built by go build)
/jamsesh-router

# Frontend build output copied into assets package for go:embed
# The .gitkeep and .gitignore inside this dir are tracked; build artifacts are not.
internal/portal/assets/dist/*
!internal/portal/assets/dist/.gitignore
!internal/portal/assets/dist/.gitkeep

# Test artifacts
/jamsesh
jamsesh.db

# Un-ignore the plugin skill dir named jamsesh
!skills/jamsesh/

# Claude Code harness — transient lock file; mutates during scheduled-task runs
.claude/scheduled_tasks.lock

# Local dev compose data
.data/

# air build artifacts
tmp/
